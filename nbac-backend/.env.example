# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=

# JWT Configuration
JWT_ACCESS_SECRET=your_access_token_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# File Upload Configuration
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Institution Information (used in NAAC Report Section 1)
COLLEGE_NAME=Your College Name Here
PROGRAM_NAME=B.Tech / BE
